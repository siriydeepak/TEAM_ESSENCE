# TEAM_ESSENCE Monorepo Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Production: Vercel Postgres connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/aethershelf

# Development: SQLite fallback (auto-created if DATABASE_URL not available)
SQLITE_DB_PATH=./database.sqlite

# =============================================================================
# WEATHER API CONFIGURATION
# =============================================================================

# OpenWeatherMap API Key (required for weather-based shelf life adjustments)
# Get your free API key at: https://openweathermap.org/api
OWM_API_KEY=your_openweathermap_api_key_here

# Default city for weather data (can be overridden by user)
DEFAULT_CITY=London

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================

# NextAuth.js configuration (if using authentication)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application environment
NODE_ENV=development

# Frontend URL (for CORS and API calls)
FRONTEND_URL=http://localhost:3000

# Backend URL (for API calls)
BACKEND_URL=http://localhost:8000

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# MongoDB (if using for additional data storage)
MONGODB_URI=mongodb://localhost:27017/aethershelf

# Email service (for notifications)
EMAIL_SERVICE_API_KEY=your_email_service_api_key_here

# Push notification service (for mobile alerts)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable debug logging
DEBUG=true

# Enable development features
DEV_MODE=true

# API rate limiting (requests per minute)
RATE_LIMIT=100

# =============================================================================
# VERCEL DEPLOYMENT CONFIGURATION
# =============================================================================

# These are automatically set by Vercel, but can be overridden
# VERCEL=1
# VERCEL_URL=your-app.vercel.app
# VERCEL_ENV=production

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT secret for token signing
JWT_SECRET=your_jwt_secret_here

# Session secret for secure sessions
SESSION_SECRET=your_session_secret_here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://your-domain.vercel.app

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable specific features
ENABLE_WEATHER_INTEGRATION=true
ENABLE_RECEIPT_PARSING=true
ENABLE_SMART_SHOPPING=true
ENABLE_ANALYTICS=true
ENABLE_PUSH_NOTIFICATIONS=false

# =============================================================================
# LOGGING AND MONITORING
# =============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable performance monitoring
ENABLE_MONITORING=false

# Sentry DSN (for error tracking)
SENTRY_DSN=your_sentry_dsn_here