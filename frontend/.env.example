# Frontend Environment Variables

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Backend API URL
# Development: http://localhost:8000/api
# Production: https://your-domain.vercel.app/api
VITE_API_URL=http://localhost:8000/api

# Application version
VITE_APP_VERSION=2.0.0

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# OpenWeatherMap API Key (for client-side weather features if needed)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# =============================================================================
# PWA CONFIGURATION
# =============================================================================

# Progressive Web App settings
VITE_PWA_NAME="AetherShelf - Smart Inventory Management"
VITE_PWA_SHORT_NAME="AetherShelf"
VITE_PWA_THEME_COLOR="#2563eb"
VITE_PWA_BACKGROUND_COLOR="#ffffff"

# PWA manifest settings
VITE_PWA_DESCRIPTION="Smart inventory management with weather integration"
VITE_PWA_DISPLAY="standalone"
VITE_PWA_ORIENTATION="portrait"
VITE_PWA_START_URL="/"
VITE_PWA_SCOPE="/"

# =============================================================================
# ANALYTICS AND MONITORING
# =============================================================================

# Google Analytics (Optional)
VITE_GA_TRACKING_ID=

# Sentry DSN for frontend error tracking (Optional)
VITE_SENTRY_DSN=

# Application Insights (Optional)
VITE_APPINSIGHTS_CONNECTION_STRING=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable frontend features
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PWA=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_WEATHER_WIDGET=true

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Development tools and debugging
VITE_DEV_TOOLS=true
VITE_MOCK_API=false
VITE_DEBUG_MODE=false

# Hot module replacement
VITE_HMR_PORT=24678
VITE_HMR_HOST=localhost

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================

# Build optimization settings
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true
VITE_BUILD_TARGET=es2015

# Chunk size warnings
VITE_CHUNK_SIZE_WARNING_LIMIT=500

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Content Security Policy settings
VITE_CSP_ENABLED=true

# API security
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# =============================================================================
# UI/UX CONFIGURATION
# =============================================================================

# Theme configuration
VITE_DEFAULT_THEME=light
VITE_THEME_PERSISTENCE=true

# Language and localization
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,es,fr,de

# Animation settings
VITE_ENABLE_ANIMATIONS=true
VITE_REDUCED_MOTION=false

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Caching settings
VITE_CACHE_DURATION=3600000
VITE_SW_CACHE_STRATEGY=CacheFirst

# Image optimization
VITE_IMAGE_LAZY_LOADING=true
VITE_IMAGE_WEBP_SUPPORT=true

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================

# Push notifications (if enabled)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Notification settings
VITE_NOTIFICATION_TIMEOUT=5000
VITE_NOTIFICATION_POSITION=top-right